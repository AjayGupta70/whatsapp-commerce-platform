# ============================================
# WhatsApp Automation Platform - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# ─── Application ─────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_NAME=whatsapp-automation
API_PREFIX=api
API_VERSION=v1

# ─── MongoDB (Messages, Chats) ───────────────
MONGO_URI=mongodb://admin:password@localhost:27017/whatsapp_automation?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=whatsapp_automation
MONGO_PORT=27017

# ─── PostgreSQL (Users, Tenants, Orders) ─────
DATABASE_URL=postgresql://admin:password@localhost:5432/whatsapp_automation?schema=public
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=whatsapp_automation
POSTGRES_PORT=5432

# ─── Redis (Sessions, Cache) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

# ─── RabbitMQ (Event Bus) ────────────────────
RABBITMQ_URL=amqp://admin:password@localhost:5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ─── JWT Auth ────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── OpenAI (LLM) ───────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3

# ─── Razorpay (Payments) ────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── WhatsApp (Baileys) ─────────────────────
WHATSAPP_SESSION_PATH=./sessions
